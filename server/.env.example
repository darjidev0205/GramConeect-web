# GramConnect Backend Environment Variables
# Copy this file to .env and fill in your values

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/gramconnect

# JWT secrets
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Server port (Render sets PORT automatically)
PORT=5000

# Frontend URL for CORS (your Vercel deployment URL)
CLIENT_URL=https://gram-coneect-web.vercel.app
FRONTEND_URL=https://gram-coneect-web.vercel.app

# Node environment
NODE_ENV=production

# Email Provider Configuration (Brevo HTTPS API for Production, Ethereal for Local Dev)
EMAIL_PROVIDER=brevo
BREVO_API_KEY=your_brevo_api_key
EMAIL_FROM_NAME=GramConnect
EMAIL_FROM_ADDRESS=your_verified_sender@example.com

# Twilio (SMS OTP)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

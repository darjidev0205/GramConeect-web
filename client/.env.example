# GramConnect Frontend Environment Variables
# Copy this file to .env and fill in your values

# Backend API URL (no trailing slash, no /api suffix)
# Local: http://localhost:5000
# Production: https://gramconnect-4hoh.onrender.com
VITE_API_URL=http://localhost:5000

# Google Maps API Key (browser-exposed, protect with HTTP referrer restrictions)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
